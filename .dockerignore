# Python build artifacts
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/

# Virtual environments
venv/
.venv/
env/

# Local dev / IDE / OS junk
.vscode/
.idea/
*.DS_Store
Thumbs.db
.claude/

# Git metadata (no need inside the image)
.git/
.gitattributes
.gitignore

# Tests and dev requirements (not needed at runtime)
tests/
requirements-dev.txt

# Docker artifacts shouldn't recurse into the build context
Dockerfile
docker-compose.yml
.dockerignore

# Docs
README.md
CLAUDE.md
METHODS.md

# PaaS configs (not needed inside the image)
render.yaml
railway.json
fly.toml
